generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum ProformaStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
  EXPIRED
}

enum RequestType {
  NEW_KIOSK
  NEW_COMPARTMENT
  UPGRADE
  MAINTENANCE
}

enum KioskBrandingType {
  MONO
  GRAND
  COMPARTIMENT
}

enum ClientType {
  PARTICULIER
  ENTREPRISE
  STAFF
}

enum ContractStatus {
  DRAFT
  PENDING
  CONFIRMED
  ACTIVE
  EXPIRED
  TERMINATED
  CANCELLED
}

enum KioskTown {
  DOUALA
  YAOUNDE
}

enum KioskType {
  MONO
  GRAND
}

enum CompartmentType {
  LEFT
  MIDDLE
  RIGHT
  SINGLE
}

enum CompartmentStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  UNDER_MAINTENANCE
}

enum KioskStatus {
  REQUEST
  LOCALIZING
  AVAILABLE
  UNDER_MAINTENANCE
  IN_STOCK
  ACTIVE
  UNACTIVE
  ACTIVE_UNDER_MAINTENANCE
  UNACTIVE_UNDER_MAINTENANCE
}

enum KioskRequestStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  UNDER_REVIEW
  CLOSED
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE
}

enum UserStatus {
  PENDING
  VERIFIED
  ONLINE
  OFFLINE
  DELETED
}

enum NotificationStatus {
  SENT
  VIEWED
}

enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  CONVERTED
  LOST
}

enum Role {
  CLIENT
  RESPONSABLE
  TECHNICIEN
  SUPERADMIN
  COMMERCIAL
  ADMIN
  JURIDIQUE
  CLIENTADMIN
  RESPONSABLEKIOSK
  COMPTABLE
}

enum DeletedEntityType {
  USER
  CONTRACT
  PROFORMA
  PROSPECT
  KIOSK
  KIOSK_COMPARTMENT
}

enum DeleteActionType {
  SOFT_DELETE
  PERMANENT_DELETE
  RESTORE
  ARCHIVE
}

// ============================================
// AUDIT & DELETION TRACKING MODELS
// ============================================

model DeletedRecord {
  id                  String            @id @default(cuid())
  originalId          String
  entityType          DeletedEntityType
  entityData          Json
  deletedBy           String
  deletedByEmail      String
  deletedAt           DateTime          @default(now())
  deleteAction        DeleteActionType   @default(SOFT_DELETE)
  restorationDate     DateTime?
  restoredBy          String?
  permanentDeleteDate DateTime?
  reason              String?           @db.Text
  ipAddress           String?
  userAgent           String?

  @@index([originalId])
  @@index([entityType])
  @@index([deletedBy])
  @@index([deletedAt])
  @@map("deleted_records")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  userId     String
  userEmail  String
  userRole   Role
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())
  details    String?  @db.Text

  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
  @@map("audit_logs")
}

// ============================================
// USER MODEL
// ============================================

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  role                 Role      @default(CLIENT)
  clientType           ClientType @default(STAFF)
  status               UserStatus @default(PENDING)
  address              String?
  phone                String?
  verificationToken    String?
  emailVerified        Boolean   @default(false)
  image                String?
  password             String?
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  notifications Notification[]

  inventoryMoves  InventoryMovement[]
  serviceRequests ServiceRequest[]    @relation("TechnicianServiceRequests")
  locationHistory LocationHistory[]

  prospects      Prospect[]       @relation("AssignedProspects")
  prospectActions ProspectAction[]
  quotes         Quote[]
  reports        Report[]

  kioskAssignments       KioskAssignment[]
  compartmentAssignments KioskCompartmentAssignment[]

  monoKiosks Kiosk[] @relation("MonoKioskClient")

  compartmentClients KioskCompartment[] @relation("CompartmentClient")

  convertedFromProspect Prospect?  @relation("ConvertedUser")
  createdProspects      Prospect[] @relation("CreatedByUser")

  proformasCreated Proforma[] @relation("ProformaCreator")
  contractsCreated Contract[] @relation("ContractCreator")
  contractsSigned  Contract[] @relation("ContractSigner")
  
  // Kiosk requests
  kioskRequests KioskRequest[] @relation("ClientRequests")

  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

// ============================================
// KIOSK REQUEST MODEL
// ============================================

model KioskRequest {
  id                    String              @id @default(cuid())
  requestNumber         String              @unique
  requestType           RequestType         @default(NEW_KIOSK)
  status                KioskRequestStatus  @default(PENDING)
  
  // Client information
  clientId              String
  client                User                @relation("ClientRequests", fields: [clientId], references: [id])
  clientName            String
  clientEmail           String?
  clientPhone           String?
  
  // Request details
  requestedKioskType    KioskType?
  requestedCompartments Json?
  wantBranding          Boolean             @default(false)
  
  // Location and business info
  kioskAddress          String?
  productTypes          String?
  managerName           String?
  managerContacts       String?
  
  // Pricing
  estimatedPrice        Float?
  
  // Metadata
  notes                 String?             @db.Text
  adminNotes            String?             @db.Text
  
  // Tracking
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  processedAt           DateTime?
  processedBy           String?
  
  // Relations
  assignedKioskId       Int?
  assignedKiosk         Kiosk?              @relation(fields: [assignedKioskId], references: [id])
  
  @@index([clientId])
  @@index([status])
  @@index([requestNumber])
  @@index([createdAt])
  @@map("kiosk_requests")
}

// ============================================
// KIOSK MODELS
// ============================================

model Kiosk {
  id                    Int        @id @default(autoincrement())
  kioskName             String
  kioskMatricule        String     @unique @default("K-000-0000-000")
  kioskType             KioskType
  kioskAddress          String?
  gpsLatitude           Float?
  gpsLongitude          Float?
  kioskTown             KioskTown  @default(DOUALA)
  productTypes          String?
  managerName           String?
  managerContacts       String?
  locationId            String?
  status                KioskStatus @default(REQUEST)
  image                 String?
  averageMonthlyRevenue Decimal?
  notes                 String?    @db.Text

  monoClientId String?
  monoClient   User?   @relation("MonoKioskClient", fields: [monoClientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  compartments    KioskCompartment[]
  kioskContracts  KioskContract[]
  inventory       KioskInventory[]
  inventoryMoves  InventoryMovement[]
  serviceRequests ServiceRequest[]
  locationHistory LocationHistory[]
  assignments     KioskAssignment[]
  requests        KioskRequest[]

  @@index([kioskMatricule])
  @@index([status])
  @@index([kioskType])
  @@map("kiosks")
}

model KioskCompartment {
  id      Int               @id @default(autoincrement())
  kioskId Int
  kiosk   Kiosk             @relation(fields: [kioskId], references: [id], onDelete: Cascade)

  compartmentType CompartmentType @default(SINGLE)
  status CompartmentStatus @default(AVAILABLE)

  clientId String?
  client   User?   @relation("CompartmentClient", fields: [clientId], references: [id])

  customName     String?
  monthlyRevenue Decimal?
  notes          String?  @db.Text

  assignedAt DateTime?
  assignedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  assignments    KioskCompartmentAssignment[]
  kioskContracts KioskContract[]              @relation("CompartmentKioskContracts")
  inventory      KioskInventory[]
  inventoryMoves InventoryMovement[]
  serviceRequests ServiceRequest[]

  @@unique([kioskId, compartmentType])
  @@index([kioskId])
  @@index([clientId])
  @@index([status])
  @@map("kiosk_compartments")
}

model KioskAssignment {
  id         String   @id @default(cuid())
  kioskId    Int
  kiosk      Kiosk    @relation(fields: [kioskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String
  assignedAt DateTime @default(now())
  assignedBy String
  isActive   Boolean  @default(true)

  @@unique([kioskId, userId, role])
  @@map("kiosk_assignments")
}

model KioskCompartmentAssignment {
  id            String           @id @default(cuid())
  compartmentId Int
  compartment   KioskCompartment @relation(fields: [compartmentId], references: [id], onDelete: Cascade)
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String
  assignedAt    DateTime         @default(now())
  assignedBy    String
  isActive      Boolean          @default(true)

  @@unique([compartmentId, userId, role])
  @@map("kiosk_compartment_assignments")
}

// ============================================
// CONTRACT MODELS
// ============================================

model Contract {
  id              String         @id @default(cuid())
  contractNumber  String         @unique
  title           String
  status          ContractStatus @default(DRAFT)
  startDate       DateTime?
  endDate         DateTime?
  signatureDate   DateTime?
  terminationDate DateTime?

  clientName              String
  clientIdNumber          String?
  clientIdIssuedDate      DateTime?
  clientIdIssuedPlace     String?
  clientAddress           String?
  clientPhone             String?
  clientBusinessAddress   String?
  clientBusinessQuarter   String?
  clientBusinessLocation  String?

  contractDuration  Int
  paymentFrequency  String
  paymentAmount     Float
  totalAmount       Float

  deletedAt DateTime?
  deletedBy String?

  createdBy   User    @relation("ContractCreator", fields: [createdById], references: [id])
  createdById String
  signedBy    User?   @relation("ContractSigner", fields: [signedById], references: [id])
  signedById  String?

  proforma Proforma? @relation("ProformaContract")

  contractDocument String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kioskContracts  KioskContract[]
  contractActions ContractAction[]
  invoices        Invoice[]

  @@index([contractNumber])
  @@index([status])
  @@index([deletedAt])
  @@map("contracts")
}

model KioskContract {
  id         String @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  kioskId    Int
  kiosk      Kiosk    @relation(fields: [kioskId], references: [id])

  compartmentId Int?
  compartment   KioskCompartment? @relation("CompartmentKioskContracts", fields: [compartmentId], references: [id])

  monthlyRent Float
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, kioskId, compartmentId])
  @@index([contractId])
  @@index([kioskId])
  @@index([compartmentId])
  @@index([isActive])
  @@map("kiosk_contracts")
}

model ContractAction {
  id          String   @id @default(cuid())
  action      String
  description String?
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([contractId])
  @@map("contract_actions")
}

// ============================================
// PROFORMA MODEL
// ============================================

model Proforma {
  id            String         @id @default(cuid())
  proformaNumber String        @unique
  status        ProformaStatus @default(DRAFT)

  clientId    String?
  clientName  String
  clientEmail String?
  clientPhone String?
  clientAddress String?

  kioskSelections Json

  subtotal    Float
  dtsp        Float
  tva         Float
  dtspRate    Float @default(3.0)
  tvaRate     Float @default(19.25)
  totalAmount Float

  kioskType    KioskBrandingType?
  quantity     Int?
  surfaces     Json?
  basePrice    Float?
  brandingPrice Float?

  createdBy   User   @relation("ProformaCreator", fields: [createdById], references: [id])
  createdById String

  contract   Contract? @relation("ProformaContract", fields: [contractId], references: [id])
  contractId String?   @unique

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiryDate    DateTime?
  sentDate      DateTime?
  acceptedDate  DateTime?
  rejectedDate  DateTime?
  convertedDate DateTime?

  pdfUrl String?

  @@index([proformaNumber])
  @@index([status])
  @@index([clientId])
  @@map("proformas")
}

// ============================================
// PROSPECT MODEL
// ============================================

model Prospect {
  id              String         @id @default(cuid())
  name            String
  contact         String?
  address         String?
  need            String?
  prospectStatus  ProspectStatus @default(NEW)
  source          String?
  estimatedValue  Decimal?
  notes           String?
  lastContactDate DateTime?
  conversionDate  DateTime?

  deletedAt DateTime?
  deletedBy String?

  convertedUserId String? @unique
  convertedUser   User?   @relation("ConvertedUser", fields: [convertedUserId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("AssignedProspects", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("CreatedByUser", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actions ProspectAction[]
  quotes  Quote[]

  @@index([prospectStatus])
  @@index([deletedAt])
  @@map("prospects")
}

model ProspectAction {
  id            String   @id @default(cuid())
  prospectId    String
  prospect      Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  actionType    String
  actionDetails String?
  createdAt     DateTime @default(now())

  @@map("prospect_actions")
}

// ============================================
// AUTHENTICATION MODELS
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// PRODUCT & INVENTORY MODELS
// ============================================

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])
  unitPrice   Decimal
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  inventory KioskInventory[]
  moves     InventoryMovement[]

  @@map("products")
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  products    Product[]

  @@map("product_categories")
}

model KioskInventory {
  id        String @id @default(cuid())
  kioskId   Int
  kiosk     Kiosk  @relation(fields: [kioskId], references: [id], onDelete: Cascade)

  compartmentId Int?
  compartment   KioskCompartment? @relation(fields: [compartmentId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity      Int       @default(0)
  lastRestocked DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([kioskId])
  @@index([compartmentId])
  @@map("kiosk_inventories")
}

model InventoryMovement {
  id      String @id @default(cuid())
  kioskId Int
  kiosk   Kiosk  @relation(fields: [kioskId], references: [id], onDelete: Cascade)

  compartmentId Int?
  compartment   KioskCompartment? @relation(fields: [compartmentId], references: [id])

  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  movementType String
  quantity     Int
  reason       String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  movementDate DateTime @default(now())

  @@index([kioskId])
  @@index([compartmentId])
  @@map("inventory_movements")
}

model ServiceRequest {
  id      String @id @default(cuid())
  kioskId Int
  kiosk   Kiosk  @relation(fields: [kioskId], references: [id], onDelete: Cascade)

  compartmentId Int?
  compartment   KioskCompartment? @relation(fields: [compartmentId], references: [id])

  technicians         User[]          @relation("TechnicianServiceRequests")
  problemDescription  String
  comments            String?
  status              ServiceRequestStatus @default(OPEN)
  priority            RequestPriority @default(MEDIUM)
  createdDate         DateTime        @default(now())
  deadLine            DateTime?
  resolvedDate        DateTime?
  attachments         String?
  updatedAt           DateTime        @updatedAt

  @@index([status])
  @@index([kioskId])
  @@index([compartmentId])
  @@map("service_requests")
}

model LocationHistory {
  id            String   @id @default(cuid())
  kioskId       Int
  kiosk         Kiosk    @relation(fields: [kioskId], references: [id], onDelete: Cascade)
  oldLocation   String?
  newLocation   String?
  validatedById String?
  validatedBy   User?    @relation(fields: [validatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@map("location_histories")
}

model Invoice {
  id              String        @id @default(cuid())
  clientOrVendor  String?
  type            String?
  issueDate       DateTime?
  termsConditions String?

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])

  amount  Decimal
  dueDate DateTime?
  status  InvoiceStatus @default(PENDING)

  payments Payment[]

  @@index([status])
  @@map("invoices")
}

model Payment {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount        Decimal
  paymentDate   DateTime
  paymentMethod String?

  @@map("payments")
}

model Quote {
  id           String    @id @default(cuid())
  prospectId   String
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  createdById  String?
  createdBy    User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  services     String?
  totalCost    Decimal?
  deadlineDate DateTime?
  pdfUrl       String?
  createdAt    DateTime  @default(now())

  @@map("quotes")
}

model Notification {
  id     String             @id @default(cuid())
  userId String
  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  message String
  status NotificationStatus @default(SENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model Report {
  id              String    @id @default(cuid())
  type            String
  generatedById   String?
  generatedBy     User?     @relation(fields: [generatedById], references: [id], onDelete: SetNull)
  validationDate  DateTime?
  createdAt       DateTime  @default(now())

  @@map("reports")
}